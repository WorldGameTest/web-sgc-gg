# --- Contact form delivery ---
# Copy this file to ".env.local" and fill in EITHER Telegram OR email (or both).
# Without any of these, submissions are just logged to the server console.

# --- Option A: Telegram bot (easiest, recommended) ---
# 1) Message @BotFather in Telegram → /newbot → copy the token.
# 2) Message @userinfobot → copy your numeric chat id.
# 3) Press Start in a chat with your new bot.
TELEGRAM_BOT_TOKEN=1234567890:AA...
TELEGRAM_CHAT_ID=123456789

# --- Option B: Email (Resend) ---
# Get a free API key at https://resend.com (Dashboard → API Keys).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Where applications are delivered:
CONTACT_TO_EMAIL=collaborationsgc@mail.com
# "From" address — must be on a domain verified in Resend. For testing,
# onboarding@resend.dev works but only delivers to your Resend account email.
CONTACT_FROM_EMAIL=Sector Games <onboarding@resend.dev>
